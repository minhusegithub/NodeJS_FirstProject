# ============================================
# Product Management - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- PostgreSQL ----
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=product_management
PG_USER=postgres
PG_PASSWORD=your_pg_password_here

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- JWT Configuration ----
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Client URL ----
CLIENT_URL=http://localhost:5173

# ---- VNPay Configuration ----
VNPAY_TMNCODE=your_vnpay_tmncode
VNPAY_SECURESECRET=your_vnpay_secret
VNPAY_HOST=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Cloudinary ----
CLOUD_NAME=your_cloud_name
CLOUD_KEY=your_cloud_key
CLOUD_SECRET=your_cloud_secret
