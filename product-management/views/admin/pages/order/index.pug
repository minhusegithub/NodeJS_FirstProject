extends ../../layouts/default.pug

include ../../mixins/alert.pug
include ../../mixins/moment.pug

block main
    
    .container.mt-4
      h2.mb-4.text-center 
        i.bi.bi-cart-fill.mr-2
        | Danh sách đơn hàng 

      +alert-success(5000)
      +alert-error(5000)

      .card.orders-card.border-0.shadow-sm.mb-4
        .card-header.d-flex.justify-content-between.align-items-center
          span.font-weight-bold.text-dark
            i.bi.bi-cart-fill.mr-2
            | Danh sách đơn hàng cần xử lí

        .card-body
          .table-responsive
            table.table.custom-table.mb-0
              thead
                tr.text-center
                  th(style="width: 50px") #
                  th Khách hàng
                  th Ảnh
                  th Tên sản phẩm
                  th Giá
                  th Số lượng
                  
                  th Phương thức thanh toán
                  th Giao hàng nhanh?
                  th Tổng tiền
                  th Ngày đặt hàng
                  th Trạng thái
                  th(style="width: 120px") Hành động

              tbody
                each item, index in orders
                  - const rowSpan = item.products.length
                  each product, productIndex in item.products
                    tr.table-row.align-middle
                      if productIndex === 0
                        td(rowspan=rowSpan) #{index + 1}
                        td(rowspan=rowSpan class="text-left")
                          if item.userInfo
                            div.fw-semibold #{item.userInfo.fullName || 'Khách lẻ'}
                            div.text-muted.small #{item.userInfo.phone || 'Chưa có số điện thoại'}
                            div.text-muted.small #{item.userInfo.address || 'Chưa có địa chỉ'}
                          else
                            span.text-muted Chưa có thông tin khách hàng
                      
                      td
                        img.rounded.border(
                          src=product.thumbnail
                          alt=product.title
                          width="50"
                          height="50"
                          style="object-fit: cover;"
                        )
                      td.text-left #{product.title}
                      td #{product.priceNew}$
                      td #{product.quantity}
                      
                        
                      if productIndex === 0
                        td(rowspan=rowSpan) #{item.paymentMethod}
                        td(rowspan=rowSpan)
                          span.status-badge(class=item.isPlaceRushOrder ? "status-active" : "status-inactive")
                            | #{item.isPlaceRushOrder ? "Có" : "Không"}
                        td(rowspan=rowSpan) #{item.totalPrice}$
                        td(rowspan=rowSpan)
                          +formatDateTime(item.createdAt)
                        td(rowspan=rowSpan)
                          span.status-badge(class=item.status === "Processing" ? "status-processing" : item.status === "Delivering" ? "status-delivering" : "status-cancelled")
                            | #{item.status}
                        td(rowspan=rowSpan)
                          div.dropdown
                            button.icon-btn.dropdown-toggle(type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Hành động")
                              span(data-lucide="more-vertical" style="width: 18px; height: 18px;")
                            .dropdown-menu
                              if item.status === "Processing"
                                a.dropdown-item(href="javascript:;" data-status=item.status data-id=item.id button-change-order-status data-status-change="Delivering")
                                  span(data-lucide="truck" style="width: 16px; height: 16px;")
                                  | Giao hàng
                                .dropdown-divider
                                a.dropdown-item.text-danger-600(href="javascript:;" data-status=item.status data-id=item.id button-change-order-status data-status-change="Cancelled")
                                  span(data-lucide="x-circle" style="width: 16px; height: 16px;")
                                  | Hủy đơn
                    if productIndex === rowSpan - 1
                      tr.item-divider
                        td(colspan="12")
                          div.divider-line

    form(
      action=""
      method="POST"
      id="form-change-order-status"
      data-path=`${prefixAdmin}/orders/change-status`
    )

    script(src="/admin/js/script.js")

    style.
      .orders-card {
        border-radius: 16px;
      }
      .orders-card .card-header {
        padding: 18px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
      }
      .orders-card .card-body {
        padding: 24px;
      }
      .custom-table {
        font-family: 'Inter','Poppins',sans-serif;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 130%;
      }
      .custom-table thead th {
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        border-bottom: 1px solid #e2e8f0;
        text-align: center;
      }
      
      .custom-table td.text-left {
        text-align: left;
      }
      .custom-table th, .custom-table td {
        padding: 16px 14px;
        height: 60px;
        vertical-align: middle;
        border-top: none;
        text-align: center;
      }
      .custom-table tbody tr.table-row {
        border-bottom: 1px solid #e5e7eb;
        transition: all 0.2s ease;
      }
      .custom-table tbody tr.table-row:last-child {
        border-bottom: none;
      }
      .custom-table tbody tr.table-row:hover {
        background: #f8fbff;
        //- box-shadow: inset 0 0 0 2px #1E4A7B;
      }
      .status-badge {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
      }
      .status-active {
        background: #e8f2ff;
        color: #1E4A7B;
      }
      .status-inactive {
        background: #fdecef;
        color: #E5989B;
      }
      .status-processing {
        background: #fef3c7;
        color: #d97706;
      }
      .status-delivering {
        background: #dcfce7;
        color: #16a34a;
      }
      .status-cancelled {
        background: #fee2e2;
        color: #dc2626;
      }
      .icon-btn {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .icon-btn:hover {
        border-color: #1E4A7B;
        background: #e8f2ff;
        color: #1E4A7B;
      }
      .dropdown-menu {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        min-width: 140px;
      }
      .dropdown-item {
        font-size: 13px;
        color: #475569;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        transition: all 0.15s ease;
      }
      .dropdown-item:hover {
        background: #f8fbff;
        color: #1E4A7B;
      }
      .text-danger-600 {
        color: #dc2626;
      }
      .item-divider td {
        padding: 0;
        border: none;
        background: transparent;
      }
      .divider-line {
        width: 100%;
        height: 2px;
        background: #1E4A7B;
        border-radius: 2px;
      }
