extend ../../layouts/auth.pug

include ../../mixins/alert.pug


block main 
    +alert-error(5000)
    +alert-success(5000)

    .login-page-admin
        .container
            .row.justify-content-center.align-items-center.min-vh-100
                .col-11.col-sm-6.col-md-5.col-lg-4
                    .card.border-0.shadow.rounded-4
                        .card-body.p-4
                            .text-center.mb-4
                                h2.fw-bold.admin-css Admin 
                                
                            
                            form(
                                action=`${prefixAdmin}/auth/login`
                                method="POST"
                                autocomplete="off"
                            )
                                .form-group.mb-3
                                    input(
                                        type="email"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="email"
                                        name="email"
                                        placeholder="Email"
                                        required
                                    )

                                .form-group.mb-3
                                    input(
                                        type="password"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="password"
                                        name="password"
                                        placeholder="Mật khẩu"
                                        required
                                    )

                                button(
                                    type="submit"
                                    class="btn btn-primary btn-lg w-100 rounded-3"
                                ) Đăng nhập

    style.
        .admin-css {
            color: #1E4A7B;
        }
        .login-page-admin {
            background: linear-gradient(135deg, #163a63 0%, #ffffff  100%);
            min-height: 100vh;
        }
        .login-page-admin .card {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
        }
        .login-page-admin .form-control {
            padding: 0.8rem 1rem;
            font-size: 15px;
        }
        .login-page-admin .form-control:focus {
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.25);
            border: none;
        }
        .login-page-admin .form-control::placeholder {
            color: #90949c;
        }
        .login-page-admin .btn-primary {
            background: linear-gradient(135deg, #163a63 100% );
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .login-page-admin .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }
        .login-page-admin h2 {
            color: #1E4A7B;
        }
        .login-page-admin .text-muted {
            color: #6c757d !important;
        } 





