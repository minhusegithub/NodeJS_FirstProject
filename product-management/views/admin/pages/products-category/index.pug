extends ../../layouts/default.pug

include ../../mixins/table-tree.pug
include ../../mixins/moment.pug

block main   
  if role.permissions.includes("products-category_view")
    .container.mt-4
      h2.mb-4.text-center
        i.bi.bi-box-seam-fill.mr-2
        | Danh mục sản phẩm

      .card.category-card.border-0.shadow-sm.mb-4
        .card-header.d-flex.justify-content-between.align-items-center
          span.font-weight-bold.text-dark
            i.bi.bi-list-ul.mr-2
            | Danh sách danh mục
          if role.permissions.includes("products-category_create")
            a.btn.btn-primary.btn-sm(href=`${prefixAdmin}/products-category/create`)
              i.bi.bi-plus-circle.mr-1
              | Thêm mới

        .card-body
          .table-responsive
            table.table.custom-table.mb-0(checkbox-multi)
              thead
                tr.text-center
                  th
                    input(type="checkbox" name="checkall")
                  th(style="width: 60px") #
                  th Tiêu đề
                  th(style="width: 140px") Trạng thái
                  th(style="width: 120px") Hành động

              tbody
                +table-tree(records)

    // Form xóa
    form(
      action=""
      method="POST"
      id="form-delete-category"
      data-path=`${prefixAdmin}/products-category/delete`
    )

    script(src="/admin/js/products-category.js")

    style.
      .category-card {
        border-radius: 16px;
      }
      .category-card .card-header {
        padding: 18px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
      }
      .category-card .card-body {
        padding: 24px;
      }
      .custom-table {
        font-family: 'Inter','Poppins',sans-serif;
        border-collapse: separate;
        border-spacing: 0;
      }
      .custom-table thead th {
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        border-bottom: 1px solid #e2e8f0;
      }
      .custom-table th, .custom-table td {
        padding: 16px 14px;
        height: 60px;
        vertical-align: middle;
        border-top: none;
      }
      .custom-table tbody tr.table-row {
        border-bottom: 1px solid #e5e7eb;
        transition: all 0.2s ease;
      }
      .custom-table tbody tr.table-row:last-child {
        border-bottom: none;
      }
      .custom-table tbody tr.table-row:hover {
        background: #f8fbff;
        box-shadow: inset 0 0 0 2px #1E4A7B;
      }
      .status-badge {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
      }
      .status-active {
        background: #e8f2ff;
        color: #1E4A7B;
      }
      .status-inactive {
        background: #fdecef;
        color: #E5989B;
      }
      .icon-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        color: #475569;
        background: #fff;
        padding: 0;
      }
      .icon-btn:hover {
        border-color: #1E4A7B;
        color: #1E4A7B;
        background: #f8fbff;
      }
      .dropdown-menu {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,47,79,0.12);
      }
      .dropdown-item { font-size: 14px; }
      .btn-primary {
        background: #1E4A7B;
        border-color: #1E4A7B;
      }
      .btn-primary:hover {
        background: #16385c;
        border-color: #16385c;
      }
