extends ../../layouts/default.pug

include ../../mixins/alert.pug

block main
    .container.py-4
        .row.justify-content-center
            .col-lg-8
                .card.detail-card.border-0.shadow-lg.rounded-4.overflow-hidden
                    .card-header.bg-gradient-primary.text-white.py-4
                        .d-flex.align-items-center
                            
                            div
                                h1(class="h3 mb-0 fw-bold") Chi tiết danh mục
                                
                    
                    .card-body.p-4
                        .row.g-4
                            if(data.title)
                                .col-md-6
                                    .info-item.surface.p-3.rounded-3
                                        .text-muted.small Tiêu đề
                                        .fw-bold #{data.title}
                            
                            if(data.position)
                                .col-md-6
                                    .info-item.surface.p-3.rounded-3
                                        .text-muted.small Vị trí
                                        .fw-bold #{data.position}

                            if(data.thumbnail)
                                .col-12
                                    .info-item.surface.p-3.rounded-3
                                        .text-muted.small.mb-2 Hình ảnh
                                        img(
                                            src=data.thumbnail
                                            class="rounded-3 shadow-sm"
                                            style="width: 200px; height: 200px; object-fit: cover;"
                                        )

                            if(data.status)
                                .col-md-6
                                    .info-item.surface.p-3.rounded-3
                                        .text-muted.small Trạng thái
                                        if(data.status === "active")
                                            span.badge.status-badge.status-active
                                                i(class="fas fa-check-circle me-1")
                                                | Hoạt động
                                        else
                                            span.badge.status-badge.status-inactive
                                                i(class="fas fa-times-circle me-1")
                                                | Dừng hoạt động

                            if(data.description)
                                .col-12
                                    .info-item.surface.p-3.rounded-3
                                        .text-muted.small Mô tả
                                        .fw-medium !{data.description}

                        .d-flex.justify-content-end.mt-4
                            a(class="btn btn-outline-secondary" onclick="window.history.back()")
                                
                                | Quay lại
                            if(role.permissions.includes("products-category_edit"))
                                a(
                                    href=`${prefixAdmin}/products-category/edit/${data.id}`
                                    class="btn btn-primary"
                                )
                                    
                                    | Chỉnh sửa

    style.
        .detail-card { border-radius: 18px; box-shadow: 0 12px 28px rgba(15,47,79,0.12); }
        .bg-gradient-primary { background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%); }
        .icon-circle {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        }
        .surface {
            background: #f8fbff;
            border: 1px solid #e5e7eb;
        }
        .info-item { transition: all 0.25s ease; }
        .info-item:hover { transform: translateY(-2px); box-shadow: 0 12px 22px rgba(15,47,79,0.12); }
        .status-badge {
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-active { background: #e8f2ff; color: #1E4A7B; }
        .status-inactive { background: #fdecef; color: #E5989B; }
        .btn-primary { background: #1E4A7B; border-color: #1E4A7B; }
        .btn-primary:hover { background: #16385c; border-color: #16385c; }
        .btn-outline-secondary:hover { color: #1E4A7B; border-color: #1E4A7B; }
    
    