extends ../../layouts/default.pug

include ../../mixins/alert.pug
include ../../mixins/select-tree.pug

block main
    if(role.permissions.includes("products-category_edit"))
        .container.py-4
            .row.justify-content-center
                .col-lg-8
                    .card.edit-card.border-0.shadow-lg.rounded-4.overflow-hidden
                        .card-header.bg-gradient-primary.text-white.py-4
                            .d-flex.align-items-center
                                
                                div
                                    h1(class="h3 mb-0 fw-bold") Chỉnh sửa danh mục
                                    
                        
                        .card-body.p-4
                            +alert-success(5000)
                            +alert-error(5000)

                            form(
                                action=`${prefixAdmin}/products-category/edit/${data.id}?_method=PATCH`
                                method="POST"
                                enctype="multipart/form-data"
                            )
                                .row.g-4
                                    .col-md-12
                                        .form-group
                                            label(for="title" class="form-label fw-medium") Tiêu đề
                                            input(
                                                type="text"
                                                class="form-control form-control-lg"
                                                id="title"
                                                name="title"
                                                required
                                                value=data.title
                                                placeholder="Nhập tiêu đề danh mục"
                                            )

                                    .col-md-12
                                        .form-group
                                            label(for="parent_id" class="form-label fw-medium") Danh mục cha
                                            select(
                                                name="parent_id"
                                                id="parent_id"
                                                class="form-select form-select-lg"
                                            )
                                                option(value="")  Chọn danh mục cha 
                                                if(records)
                                                    +select-tree(records, 1, data.parent_id)

                                    .col-md-12
                                        .form-group
                                            label(for="desc" class="form-label fw-medium") Mô tả
                                            textarea(
                                                class="form-control form-control-lg"
                                                id="desc"
                                                name="description"
                                                rows="5"
                                                placeholder="Nhập mô tả danh mục"
                                            ) #{data.description}

                                    .col-md-12
                                        .form-group
                                            label(for="thumbnail" class="form-label fw-medium") Ảnh
                                            .upload-area.border.rounded-3.p-3.text-center(
                                                upload-image
                                                onclick="document.getElementById('thumbnail').click()"
                                            )
                                                input(
                                                    type="file"
                                                    class="form-control-file"
                                                    id="thumbnail"
                                                    name="thumbnail"
                                                    accept="image/*"
                                                    upload-image-input
                                                    style="display: none;"
                                                )
                                                img(
                                                    src=data.thumbnail
                                                    upload-image-preview
                                                    class="image-preview rounded-3 shadow-sm mb-3"
                                                    style="max-width: 200px;"
                                                )
                                                .upload-placeholder(style="display: none;")
                                                    i(class="fas fa-cloud-upload-alt fa-3x text-muted mb-3")
                                                    p(class="text-muted mb-0") Kéo thả ảnh vào đây hoặc click để chọn
                                                    p(class="text-muted small") Hỗ trợ: JPG, PNG, GIF

                                    .col-md-6
                                        .form-group
                                            label(for="position" class="form-label fw-medium") Vị trí
                                            input(
                                                type="number"
                                                class="form-control form-control-lg"
                                                id="position"
                                                name="position"
                                                placeholder="Tự động tăng"
                                                min="1"
                                                value=data.position
                                            )

                                    .col-md-6
                                        .form-group
                                            label(class="form-label fw-medium d-block") Trạng thái
                                            .btn-group.w-100(role="group")
                                                input(
                                                    type="radio"
                                                    class="btn-check"
                                                    id="statusActive"
                                                    name="status"
                                                    value="active"
                                                    checked=(data.status == "active" ? true : false)
                                                )
                                                label(
                                                    class="btn btn-status"
                                                    for="statusActive"
                                                )
                                                    | Hoạt động
                                                
                                                input(
                                                    type="radio"
                                                    class="btn-check"
                                                    id="statusInactive"
                                                    name="status"
                                                    value="inactive"
                                                    checked=(data.status == "inactive" ? true : false)
                                                )
                                                label(
                                                    class="btn btn-status"
                                                    for="statusInactive"
                                                )                                                
                                                    | Dừng hoạt động

                                .d-flex.justify-content-end.mt-4
                                    a(class="btn btn-outline-secondary" href=`${prefixAdmin}/products-category`)
                                        
                                        | Quay lại
                                    button(
                                        type="submit"
                                        class="btn btn-primary"
                                    )
                                        
                                        | Cập nhật

    style.
        .edit-card { border-radius: 18px; box-shadow: 0 12px 28px rgba(15,47,79,0.12); }
        .bg-gradient-primary { background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%); }
        .icon-circle {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        }
        .upload-area {
            transition: all 0.3s ease;
            cursor: pointer;
            background: #f8fbff;
            border: 1px solid #e5e7eb;
        }
        .upload-area:hover {
            border-color: #1E4A7B !important;
            background-color: rgba(30, 74, 123, 0.06);
        }
        .btn { transition: all 0.3s ease; }
        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: #1E4A7B; border-color: #1E4A7B; }
        .btn-primary:hover { background: #16385c; border-color: #16385c; }
        .btn-outline-secondary:hover { color: #1E4A7B; border-color: #1E4A7B; }
        .btn-outline-primary {
            color: #1E4A7B;
            border-color: #1E4A7B;
        }
        .btn-outline-primary:hover, .btn-outline-primary.active, .btn-outline-primary:focus {
            background: #e8f2ff;
            color: #1E4A7B;
            border-color: #1E4A7B;
        }
        .btn-outline-rose {
            color: #E5989B;
            border-color: #E5989B;
        }
        .btn-outline-rose:hover, .btn-outline-rose.active, .btn-outline-rose:focus {
            background: #fdecef;
            color: #E5989B;
            border-color: #E5989B;
        }
        .btn-status { 
            flex: 1;
            border-radius: 12px;
            padding: 10px 0;
            font-weight: 600;

        }
        .form-control, .form-select {
            transition: all 0.3s ease;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }
        .form-control:focus, .form-select:focus {
            border-color: #1E4A7B;
            box-shadow: 0 0 0 0.25rem rgba(30, 74, 123, 0.18);
        }

    
    script(src="/admin/js/script.js")