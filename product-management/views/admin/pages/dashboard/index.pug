extends ../../layouts/default.pug

block main 
    .container-fluid
        .d-flex.align-items-center.mb-4
            span(data-lucide="layout-dashboard" style="width: 32px; height: 32px; color: #1E4A7B;")
            h2.mb-0.ms-3(style="font-weight: 700; color: #111827; margin-left: 12px;") Tổng quan
        //- Statistics Overview
        .row.mb-4
            .col-lg-3.col-md-6.mb-4
                .card.stat-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-start
                            div
                                .stat-card-title.mb-2 Danh mục sản phẩm
                                .stat-value.mb-1 #{statistic.categoryProduct.total}
                                .stat-sub
                                    span(style="color: #1E4A7B;") #{statistic.categoryProduct.active} active
                            .icon-badge
                                span(data-lucide="grid-3x3" style="width: 20px; height: 20px;")
            
            .col-lg-3.col-md-6.mb-4
                .card.stat-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-start
                            div
                                .stat-card-title.mb-2 Sản phẩm
                                .stat-value.mb-1 #{statistic.product.total}
                                .stat-sub
                                    span(style="color: #1E4A7B;") #{statistic.product.active} active
                            .icon-badge.green
                                span(data-lucide="package" style="width: 20px; height: 20px;")
            
            .col-lg-3.col-md-6.mb-4
                .card.stat-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-start
                            div
                                .stat-card-title.mb-2 Tài khoản quản trị
                                .stat-value.mb-1 #{statistic.account.total}
                                .stat-sub
                                    span(style="color: #1E4A7B;") #{statistic.account.active} active
                            .icon-badge.pink
                                span(data-lucide="shield" style="width: 20px; height: 20px;")
            
            .col-lg-3.col-md-6.mb-4
                .card.stat-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-start
                            div
                                .stat-card-title.mb-2 Tài khoản người dùng
                                .stat-value.mb-1 #{statistic.user.total}
                                .stat-sub
                                    span(style="color: #1E4A7B;") #{statistic.user.active} active
                            .icon-badge(style="background: #fef3c7; color: #d97706;")
                                span(data-lucide="users" style="width: 20px; height: 20px;")
        
        //- Chart Statistics
        .row
            .col-lg-6.mb-4
                .card.chart-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-center.mb-4
                            div
                                h5.mb-1(style="font-weight: 600; color: #111827;") Danh mục & Sản phẩm
                                p.mb-0.text-muted(style="font-size: 13px;") Trạng thái hoạt động
                            span(data-lucide="bar-chart-3" style="width: 20px; height: 20px; color: #6b7280;")
                        canvas#chartCategory(style="max-height: 280px;")
            
            .col-lg-6.mb-4
                .card.chart-card.border-0
                    .card-body
                        .d-flex.justify-content-between.align-items-center.mb-4
                            div
                                h5.mb-1(style="font-weight: 600; color: #111827;") Thống kê tài khoản
                                p.mb-0.text-muted(style="font-size: 13px;") Quản trị & Người dùng
                            span(data-lucide="pie-chart" style="width: 20px; height: 20px; color: #6b7280;")
                        canvas#chartAccounts(style="max-height: 280px;")

    script.
        document.addEventListener('DOMContentLoaded', function() {
            // Statistics Data
            const stats = {
                categoryProduct: {
                    active: #{statistic.categoryProduct.active},
                    inactive: #{statistic.categoryProduct.inactive},
                    total: #{statistic.categoryProduct.total}
                },
                product: {
                    active: #{statistic.product.active},
                    inactive: #{statistic.product.inactive},
                    total: #{statistic.product.total}
                },
                account: {
                    active: #{statistic.account.active},
                    inactive: #{statistic.account.inactive},
                    total: #{statistic.account.total}
                },
                user: {
                    active: #{statistic.user.active},
                    inactive: #{statistic.user.inactive},
                    total: #{statistic.user.total}
                }
            };

            // Colors
            const colors = {
                active: '#1E4A7B',
                inactive: '#E5989B'
            };

            // Bar Chart - Categories & Products
            const ctxCategory = document.getElementById('chartCategory');
            if (ctxCategory) {
                new Chart(ctxCategory, {
                    type: 'bar',
                    data: {
                        labels: ['Danh mục', 'Sản phẩm'],
                        datasets: [
                            {
                                label: 'Hoạt động',
                                data: [stats.categoryProduct.active, stats.product.active],
                                backgroundColor: colors.active,
                                borderRadius: 8,
                                barThickness: 40
                            },
                            {
                                label: 'Dừng hoạt động',
                                data: [stats.categoryProduct.inactive, stats.product.inactive],
                                backgroundColor: colors.inactive,
                                borderRadius: 8,
                                barThickness: 40
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 15,
                                    font: { size: 12, family: 'Inter' },
                                    usePointStyle: true,
                                    pointStyle: 'circle'
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f3f4f6' },
                                ticks: { font: { family: 'Inter' } }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { font: { family: 'Inter', weight: '500' } }
                            }
                        }
                    }
                });
            }

            // Bar Chart - Accounts
            const ctxAccounts = document.getElementById('chartAccounts');
            if (ctxAccounts) {
                new Chart(ctxAccounts, {
                    type: 'bar',
                    data: {
                        labels: ['Quản trị', 'Người dùng'],
                        datasets: [
                            {
                                label: 'Hoạt động',
                                data: [stats.account.active, stats.user.active],
                                backgroundColor: colors.active,
                                borderRadius: 8,
                                barThickness: 40
                            },
                            {
                                label: 'Dừng hoạt động',
                                data: [stats.account.inactive, stats.user.inactive],
                                backgroundColor: colors.inactive,
                                borderRadius: 8,
                                barThickness: 40
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 15,
                                    font: { size: 12, family: 'Inter' },
                                    usePointStyle: true,
                                    pointStyle: 'circle'
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f3f4f6' },
                                ticks: { font: { family: 'Inter' } }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { font: { family: 'Inter', weight: '500' } }
                            }
                        }
                    }
                });
            }
        });
    style.
        .stat-card, .chart-card {
            transition: all 0.3s ease;
            border: 2px solid transparent !important;
            border-radius: 16px;
        }
        .stat-card:hover, .chart-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(15,47,79,0.14) !important;
            border: 2px solid #1E4A7B !important;
        }

