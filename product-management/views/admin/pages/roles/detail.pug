extend ../../layouts/default.pug

block main  
    .container.py-5
        .row.justify-content-center
            .col-lg-8.col-md-10
                .card.border-0.shadow-lg.rounded-4.overflow-hidden
                    .card-header.bg-gradient-primary.text-white.py-4
                        .d-flex.align-items-center
                            
                               
                            div
                                h1(class="h3 mb-0 fw-bold") Chi tiết nhóm quyền
                                
                    
                    .card-body.p-4.bg-light
                        .row.g-4
                            .col-12
                                .card.border-0.shadow-sm
                                    .card-body
                                        .d-flex.align-items-center.mb-3
                                           
                                            h5(class="mb-0") Nhóm quyền
                                        if(data.title)
                                            p(class="mb-0 text-muted") #{data.title}
                            
                            .col-12
                                .card.border-0.shadow-sm
                                    .card-body
                                        .d-flex.align-items-center.mb-3
                                            
                                            h5(class="mb-0") Mô tả
                                        if(data.description)
                                            p(class="mb-0 text-muted") !{data.description}
                            
                            .col-12
                                .card.border-0.shadow-sm
                                    .card-body
                                        .d-flex.align-items-center.mb-3
                                           
                                            h5(class="mb-0") Các quyền khả thi
                                        if(data.permissions)
                                            .d-flex.flex-wrap.gap-2
                                                each permission in data.permissions
                                                    span(class="badge p-4")
                                                        
                                                        | #{permission}

                        .d-grid.gap-3.d-md-flex.justify-content-md-end.mt-5
                            a(href=`${prefixAdmin}/roles` class="btn btn-outline-secondary btn-lg me-md-2")
                               
                                | Quay lại
                            if(role.permissions.includes("roles_edit"))
                                a(
                                    href=`${prefixAdmin}/roles/edit/${data.id}`
                                    class="btn btn-primary btn-lg px-4"
                                )
                                    
                                    | Chỉnh sửa
    style.
        .card { border-radius: 18px; box-shadow: 0 12px 28px rgba(15,47,79,0.12); }
        .bg-gradient-primary { background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%); }
        .icon-circle {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        }
        .card-body { background: #fff; }
        .btn { transition: all 0.3s ease; }
        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: #1E4A7B; border-color: #1E4A7B; }
        .btn-primary:hover { background: #16385c; border-color: #16385c; }
        .btn-outline-secondary:hover { color: #1E4A7B; border-color: #1E4A7B; }
        .badge {
            background: #e8f2ff;
            color: #1E4A7B;
            border-radius: 12px;
            transition: all 0.3s ease;
        }
        .badge:hover { transform: scale(1.05); }


