extends ../../layouts/default.pug

block main
  if role.permissions.includes("roles_view")
    .container.mt-4
      h2.mb-4.text-center 
        i.bi.bi-shield-lock-fill.mr-2
        | Danh sách nhóm quyền

      .card.roles-card.border-0.shadow-sm.mb-4
        .card-header.d-flex.justify-content-between.align-items-center
          span.font-weight-bold.text-dark
            i.bi.bi-list-check.mr-2
            | Danh sách nhóm quyền
          if role.permissions.includes("roles_create")
            a.btn.btn-primary.btn-sm(href=`${prefixAdmin}/roles/create`)
              i.bi.bi-plus-circle.mr-1
              | Thêm mới

        .card-body
          .table-responsive
            table.table.custom-table.mb-0
              thead
                tr.text-center
                  th(style="width: 60px") #
                  th Nhóm quyền
                  th Mô tả ngắn
                  th(style="width: 120px") Hành động

              tbody
                if records.length > 0
                  each item, index in records
                    tr.table-row.align-middle
                      td #{index + 1}
                      td #{item.title}
                      td #{item.description}
                      td 
                        .dropdown
                          button.btn.btn-light.btn-sm.icon-btn.dropdown-toggle(
                            type="button"
                            data-toggle="dropdown"
                            aria-expanded="false"
                            title="Tùy chọn"
                          )
                            i.bi.bi-three-dots-vertical
                          .dropdown-menu.dropdown-menu-right
                            a.dropdown-item(href=`${prefixAdmin}/roles/detail/${item.id}`)
                              
                              | Xem chi tiết
                            if role.permissions.includes("roles_edit")
                              a.dropdown-item(href=`${prefixAdmin}/roles/edit/${item.id}`)
                                
                                | Chỉnh sửa
                            if role.permissions.includes("roles_delete")
                              button.dropdown-item.text-danger(
                                type="button"
                                button-delete
                                data-id=item.id
                              )
                                
                                | Xóa
                else
                  tr
                    td(colspan="4" class="text-center text-muted") 
                      i.bi.bi-info-circle-fill.mr-1
                      | Chưa có nhóm quyền nào được tạo

    style.
      .roles-card {
        border-radius: 16px;
      }
      .roles-card .card-header {
        padding: 18px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
      }
      .roles-card .card-body {
        padding: 24px;
      }
      .custom-table {
        font-family: 'Inter','Poppins',sans-serif;
        border-collapse: separate;
        border-spacing: 0;
      }
      .custom-table thead th {
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        border-bottom: 1px solid #e2e8f0;
      }
      .custom-table th, .custom-table td {
        padding: 16px 14px;
        height: 60px;
        vertical-align: middle;
        border-top: none;
        text-align: center;
      }
      .custom-table tbody tr.table-row {
        border-bottom: 1px solid #e5e7eb;
        transition: all 0.2s ease;
      }
      .custom-table tbody tr.table-row:last-child {
        border-bottom: none;
      }
      .custom-table tbody tr.table-row:hover {
        background: #f8fbff;
        box-shadow: inset 0 0 0 2px #1E4A7B;
      }
      .icon-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        color: #475569;
        background: #fff;
        padding: 0;
      }
      .icon-btn:hover {
        border-color: #1E4A7B;
        color: #1E4A7B;
        background: #f8fbff;
      }
      .dropdown-menu {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15,47,79,0.12);
      }
      .dropdown-item { font-size: 14px; }
      .btn-primary {
        background: #1E4A7B;
        border-color: #1E4A7B;
      }
      .btn-primary:hover {
        background: #16385c;
        border-color: #16385c;
      }

    // Form xóa
    form(
      action=""
      method="POST"
      id="form-delete-roles"
      data-path=`${prefixAdmin}/roles/delete`
    )

    script(src="/admin/js/roles.js")
