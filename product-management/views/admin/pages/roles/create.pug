extends ../../layouts/default.pug

include ../../mixins/alert.pug

block main  
    .container.py-5
        .row.justify-content-center
            .col-lg-8.col-md-10
                .card.border-0.shadow-lg.rounded-4.overflow-hidden
                    .card-header.bg-gradient-primary.text-white.py-4
                        .d-flex.align-items-center
                            .icon-circle.bg-white.text-primary.rounded-circle.p-3.me-3
                                i(class="fas fa-user-shield fa-2x")
                            div
                                h1(class="h3 mb-0 fw-bold") Thêm mới nhóm quyền
                                p(class="text-white-50 mb-0") Tạo nhóm quyền mới cho hệ thống
                    
                    .card-body.p-4.bg-light
                        if(role.permissions.includes("roles_create"))
                            form(
                                action=`${prefixAdmin}/roles/create`
                                method="POST"
                            )
                                .row.g-4
                                    .col-12
                                        .form-floating
                                            label(for="title")
                                                i(class="fas fa-heading me-2")
                                                | Tiêu đề
                                            input(
                                                type="text"
                                                class="form-control border-0 shadow-sm"
                                                id="title"
                                                name="title"
                                                placeholder="Tiêu đề"
                                                required 
                                            )
                                    
                                    .col-12
                                        .form-floating
                                            label(for="desc")
                                                i(class="fas fa-info-circle me-2")
                                                | Mô tả
                                            input(
                                                type="text"
                                                class="form-control border-0 shadow-sm"
                                                id="desc"                
                                                name="description"
                                                placeholder="Mô tả"
                                            )

                                .d-grid.gap-3.d-md-flex.justify-content-md-end.mt-5
                                    a(href=`${prefixAdmin}/roles` class="btn btn-outline-secondary btn-lg me-md-2")
                                       
                                        | Quay lại
                                    button(
                                        type="submit"
                                        class="btn btn-primary btn-lg px-4"
                                    )
                                        
                                        | Tạo mới
    style.
        .card { border-radius: 18px; box-shadow: 0 12px 28px rgba(15,47,79,0.12); }
        .bg-gradient-primary { background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%); }
        .icon-circle {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        }
        .card-body { background: #fff; }
        .form-floating > .form-control:focus,
        .form-floating > .form-control:not(:placeholder-shown) {
            padding-top: 1.625rem;
            padding-bottom: 0.625rem;
        }
        .form-floating > label {
            padding: 1rem 0.75rem;
        }
        .btn { transition: all 0.3s ease; }
        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: #1E4A7B; border-color: #1E4A7B; }
        .btn-primary:hover { background: #16385c; border-color: #16385c; }
        .btn-outline-secondary:hover { color: #1E4A7B; border-color: #1E4A7B; }
        .form-control {
            transition: all 0.3s ease;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #f8fbff;
        }
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(30, 74, 123, 0.18);
            border-color: #1E4A7B;
            background: #fff;
        }

