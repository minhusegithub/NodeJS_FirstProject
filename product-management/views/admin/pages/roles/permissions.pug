extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main  
    if(role.permissions.includes("roles_permissions"))
        .container.py-5
            .card.border-0.shadow-lg.rounded-4.overflow-hidden
                .card-header.bg-gradient-primary.text-white.py-4
                    .d-flex.align-items-center
                        
                        div
                            h1(class="h3 mb-0 fw-bold") Phân quyền
                            
                
                .card-body.p-4.bg-light
                    +alert-success(5000)
                    +alert-error(5000)

                    if(records)
                        div(data-records= records)

                        .table-responsive
                            table(
                                class="table table-hover align-middle"
                                table-permissions
                            )
                                thead 
                                    tr 
                                        th(class="fw-medium") Tính năng\Quyền
                                        each item in records 
                                            th(class="text-center fw-medium") #{item.title}
                                    
                                tbody 
                                    tr(data-name="id")
                                        td 
                                        each item in records
                                            td(class="text-center")
                                                input(type="text" value=item.id)
                                    //- Danh mục sản phẩm
                                    tr.bg-light
                                        td(colspan="4")
                                            b Danh mục sản phẩm 
                                    tr(data-name="products-category_view")
                                        td Xem
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products-category_view`
                                                        checked=item.permissions.includes("products-category_view")
                                                    )
                                            
                                    tr(data-name="products-category_create")
                                        td Thêm mới
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products-category_create`
                                                        checked=item.permissions.includes("products-category_create")
                                                    )
                                    tr(data-name="products-category_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products-category_edit`
                                                        checked=item.permissions.includes("products-category_edit")
                                                    )
                                    tr(data-name="products-category_delete")
                                        td Xóa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products-category_delete`
                                                        checked=item.permissions.includes("products-category_delete")
                                                    )

                                    //- Sản phẩm
                                    tr.bg-light
                                        td(colspan="4")
                                            b Sản phẩm 
                                    tr(data-name="products_view")
                                        td Xem
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products_view`
                                                        checked=item.permissions.includes("products_view")
                                                    )
                                            
                                    tr(data-name="products_create")
                                        td Thêm mới
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products_create`
                                                        checked=item.permissions.includes("products_create")
                                                    )
                                    tr(data-name="products_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products_edit`
                                                        checked=item.permissions.includes("products_edit")
                                                    )
                                    tr(data-name="products_delete")
                                        td Xóa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},products_delete`
                                                        checked=item.permissions.includes("products_delete")
                                                    )

                                    //- Nhóm quyền
                                    tr.bg-light
                                        td(colspan="4")
                                            b Phân quyền 
                                    tr(data-name="roles_view")
                                        td Xem
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},roles_view`
                                                        checked=item.permissions.includes("roles_view")
                                                    )
                                            
                                    tr(data-name="roles_create")
                                        td Thêm mới
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},roles_create`
                                                        checked=item.permissions.includes("roles_create")
                                                    )
                                    tr(data-name="roles_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},roles_edit`
                                                        checked=item.permissions.includes("roles_edit")
                                                    )
                                    tr(data-name="roles_delete")
                                        td Xóa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},roles_delete`
                                                        checked=item.permissions.includes("roles_delete")
                                                    )
                                    tr(data-name="roles_permissions")
                                        td Phân quyền
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},roles_permissions`
                                                        checked=item.permissions.includes("roles_permissions")
                                                    )

                                    //- Tài khoản
                                    tr.bg-light
                                        td(colspan="4")
                                            b Tài khoản
                                    tr(data-name="accounts_view")
                                        td Xem
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},accounts_view`
                                                        checked=item.permissions.includes("accounts_view")
                                                    )
                                            
                                    tr(data-name="accounts_create")
                                        td Thêm mới
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},accounts_create`
                                                        checked=item.permissions.includes("accounts_create")
                                                    )
                                    tr(data-name="accounts_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},accounts_edit`
                                                        checked=item.permissions.includes("accounts_edit")
                                                    )
                                    tr(data-name="accounts_delete")
                                        td Xóa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},accounts_delete`
                                                        checked=item.permissions.includes("accounts_delete")
                                                    )
                                    
                                    //- General Settings
                                    tr.bg-light
                                        td(colspan="4")
                                            b Cài đặt chung
                                    tr(data-name="general_settings_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},general_settings_edit`
                                                        checked=item.permissions.includes("general_settings_edit")
                                                    )
                                    //- Orders
                                    tr.bg-light
                                        td(colspan="4")
                                            b Đơn hàng
                                    tr(data-name="orders_view")
                                        td Xem
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},orders_view`
                                                        checked=item.permissions.includes("orders_view")
                                                    )
                                    tr(data-name="orders_edit")
                                        td Chỉnh sửa
                                        each item in records
                                            td(class="text-center")
                                                .form-check.d-inline-block
                                                    input(
                                                        type="checkbox"
                                                        class="form-check-input"
                                                        name="permissions"
                                                        value=`${item.id},orders_edit`
                                                        checked=item.permissions.includes("orders_edit")
                                                    )




                        .d-grid.gap-3.d-md-flex.justify-content-md-end.mt-4
                            a(href=`${prefixAdmin}/roles` class="btn btn-outline-secondary btn-lg me-md-2")
                                
                                | Quay lại
                            button(
                                type="submit"
                                class="btn btn-primary btn-lg px-4"
                                button-submit
                            )
                               
                                | Cập nhật

                form(
                    id="form-change-permissions"
                    method="POST"
                    action=`${prefixAdmin}/roles/permissions?_method=PATCH`
                ) 
                    input(
                        type="text"
                        class="form-control d-none"
                        name="permissions"
                    )

                script(src="/admin/js/roles.js") 

    style.
        .bg-gradient-primary {
            background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%);
        }
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(15,47,79,0.06);
            transition: all 0.25s ease;
        }
        .card:hover {
            box-shadow: 0 12px 30px rgba(15,47,79,0.12);
        }
        .card-header {
            border-radius: 16px 16px 0 0;
            border: none;
            padding: 24px;
        }
        .card-body {
            padding: 24px;
        }
        .icon-circle {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .table {
            font-family: 'Inter','Poppins',sans-serif;
            margin-bottom: 0;
        }
        .table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            padding: 14px;
            text-align: center;
        }
        .table > :not(caption) > * > * {
            padding: 14px;
            vertical-align: middle;
            border-top: 1px solid #e5e7eb;
        }
        .table tbody tr:last-child td {
            border-bottom: 1px solid #e5e7eb;
        }
        .table tbody tr.bg-light {
            background: #f8fafc;
        }
        .table tbody tr:hover:not(.bg-light) {
            background: #f8fbff;
        }
        .table tbody tr.bg-light:hover {
            background: #f8fafc;
        }
        .table tbody tr.bg-light td {
            font-weight: 600;
            color: #1E4A7B;
            padding: 16px 14px;
        }
        .form-check-input {
            width: 1.25em;
            height: 1.25em;
            border: 2px solid #d1d5db;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .form-check-input:checked {
            background-color: #1E4A7B;
            border-color: #1E4A7B;
        }
        .form-check-input:focus {
            border-color: #1E4A7B;
            box-shadow: 0 0 0 0.25rem rgba(30, 74, 123, 0.25);
        }
        .form-check-input:hover:not(:checked) {
            border-color: #1E4A7B;
        }
        .btn {
            transition: all 0.3s ease;
            border-radius: 12px;
        }
        .btn:hover {
            transform: translateY(-1px);
        }
        .btn-primary {
            background: #1E4A7B;
            border-color: #1E4A7B;
        }
        .btn-primary:hover {
            background: #16385c;
            border-color: #16385c;
        }
        .btn-outline-secondary {
            color: #6b7280;
            border-color: #d1d5db;
        }
        .btn-outline-secondary:hover {
            background: #6b7280;
            border-color: #6b7280;
            color: #fff;
        }
        .text-muted {
            color: #6c757d !important;
        }
        .text-primary {
            color: #1E4A7B !important;
        }

                    
