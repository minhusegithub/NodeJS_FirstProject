extends ../../layouts/default.pug

include ../../mixins/alert.pug

block main  
  .container.mt-4
    .card.form-card.border-0.p-4(style="max-width: 640px; margin: 0 auto;")
      .card-body
        h2.mb-4.text-center(style="font-weight: 700; color: #111827;") 
          i.bi.bi-pencil-square.mr-2
          | Cập nhật thông tin cá nhân

        +alert-success(5000)
        +alert-error(5000)

        form(
          action=`${prefixAdmin}/my-account/edit?_method=PATCH`
          method="POST"
          enctype="multipart/form-data"
        )
          .form-group
            label(for="fullName") 
              i.bi.bi-person-fill.mr-1
              | Họ và tên *
            input.form-control(
              type="text",
              id="fullName",
              name="fullName",
              required,
              value=user.fullName
            )

          .form-group
            label(for="email") 
              i.bi.bi-envelope-fill.mr-1
              | Email *
            input.form-control(
              type="email",
              id="email",
              name="email",
              required,
              value=user.email
            )

          .form-group
            label(for="password") 
              i.bi.bi-lock-fill.mr-1
              | Mật khẩu *
            input.form-control(
              type="password",
              id="password",
              name="password"
            )

          .form-group
            label(for="phone") 
              i.bi.bi-telephone-fill.mr-1
              | Số điện thoại
            input.form-control(
              type="text",
              id="phone",
              name="phone",
              value=user.phone
            )

          .form-group(upload-image)
            label(for="avatar") 
              i.bi.bi-image-fill.mr-1
              | Ảnh đại diện
            input.form-control-file(
              type="file",
              id="avatar",
              name="avatar",
              accept="image/*",
              upload-image-input
            )
            if user.avatar
              img.mt-2.rounded.border(
                src=user.avatar,
                width="120",
                upload-image-preview
              )

          .text-center.mt-4
            button.btn.btn-primary.px-4(type="submit")
              i.bi.bi-arrow-repeat.mr-1
              | Cập nhật

    style.
      .form-card {
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(15,47,79,0.08);
        transition: all 0.3s ease;
      }
      .form-card:hover {
        border-color: #1E4A7B;
        box-shadow: 0 16px 38px rgba(15,47,79,0.14);
      }
      .form-control, .form-control-file {
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        padding: 10px 12px;
      }
      .form-control:focus {
        border-color: #1E4A7B;
        box-shadow: 0 0 0 0.2rem rgba(30,74,123,0.15);
      }
      label { font-weight: 600; color: #374151; }
      .btn-primary {
        background: #1E4A7B;
        border-color: #1E4A7B;
        border-radius: 12px;
        padding: 10px 20px;
        font-weight: 600;
      }
      .btn-primary:hover {
        background: #16385c;
        border-color: #16385c;
      }
