extends ../../layouts/default.pug

include ../../mixins/alert.pug

block main
  
  if role.permissions.includes("accounts_view")
    .container.mt-4
      h2.mb-4.text-center 
        i.bi.bi-people-fill.mr-2
        | Danh sách tài khoản

      +alert-success(5000)
      +alert-error(5000)

      .card.accounts-card.border-0.shadow-sm.mb-4
        .card-header.d-flex.justify-content-between.align-items-center
          span.font-weight-bold.text-dark
            i.bi.bi-card-list.mr-2
            | Danh sách tài khoản
          if role.permissions.includes("accounts_create")
            a.btn.btn-primary.btn-sm(href= `${prefixAdmin}/accounts/create`)
              i.bi.bi-plus-circle.mr-1
              | Thêm mới

        .card-body
          .table-responsive
            table.table.custom-table.mb-0
              thead
                tr.text-center
                  th(style="width: 50px") #
                  th Avatar
                  th Họ tên
                  th Phân quyền
                  th Email
                  th(style="width: 140px") Trạng thái
                  th(style="width: 120px") Hành động

              tbody
                each item, index in records
                  tr.table-row.text-center.align-middle
                    td #{index + 1}
                    td
                      if item.avatar
                        img.rounded-circle.border(
                          src=item.avatar,
                          alt=item.fullName,
                          width="50",
                          height="50",
                          style="object-fit: cover;"
                        )
                      else
                        span.text-muted Không có
                    td.text-left #{item.fullName}
                    td #{item.role.title}
                    td #{item.email}
                    td
                      if item.status == "active"
                        span.status-badge.status-active Hoạt động
                      else
                        span.status-badge.status-inactive Dừng hoạt động

                    td.text-center
                      .dropdown
                        button.btn.btn-light.btn-sm.icon-btn.dropdown-toggle(
                            type="button"
                            data-toggle="dropdown"
                            aria-expanded="false"
                            title="Tùy chọn"
                        )       
                          i.bi.bi-three-dots-vertical
                        .dropdown-menu.dropdown-menu-right                       
                          a.dropdown-item(href=`${prefixAdmin}/accounts/detail/${item.id}`)
                            
                            | Xem chi tiết
                          if role.permissions.includes("accounts_edit")
                            a.dropdown-item(href=`${prefixAdmin}/accounts/edit/${item.id}`)
                              
                              | Chỉnh sửa
                          if role.permissions.includes("accounts_delete")
                            button.dropdown-item.text-danger(
                                type="button"
                                button-delete
                                data-id=item.id
                            )                
                              | Xóa

      //- Form xóa
      form(
        action=""
        method="POST"
        id="form-delete-accounts"
        data-path=`${prefixAdmin}/accounts/delete`
      )

      script(src="/admin/js/account.js")

      script.
        // Initialize Bootstrap tooltips
        document.querySelectorAll('[title]').forEach(el => {
          new bootstrap.Tooltip(el);
        });

      style.
        .accounts-card {
          border-radius: 16px;
        }
        .accounts-card .card-header {
          padding: 18px 24px;
          background: #f8fafc;
          border-bottom: 1px solid #e5e7eb;
        }
        .accounts-card .card-body {
          padding: 24px;
        }
        .custom-table {
          font-family: 'Inter','Poppins',sans-serif;
          border-collapse: separate;
          border-spacing: 0;
        }
        .custom-table thead th {
          background: #f1f5f9;
          color: #475569;
          font-weight: 600;
          border-bottom: 1px solid #e2e8f0;
        }
        .custom-table th, .custom-table td {
          padding: 16px 14px;
          height: 60px;
          vertical-align: middle;
          border-top: none;
        }
        .custom-table tbody tr.table-row {
          border-bottom: 1px solid #e5e7eb;
          transition: all 0.2s ease;
        }
        .custom-table tbody tr.table-row:last-child {
          border-bottom: none;
        }
        .custom-table tbody tr.table-row:hover {
          background: #f8fbff;
          box-shadow: inset 0 0 0 2px #1E4A7B;
        }
        .status-badge {
          display: inline-block;
          padding: 6px 10px;
          border-radius: 999px;
          font-size: 12px;
          font-weight: 600;
        }
        .status-active {
          background: #e8f2ff;
          color: #1E4A7B;
        }
        .status-inactive {
          background: #fdecef;
          color: #E5989B;
        }
        .icon-btn {
          width: 34px;
          height: 34px;
          border-radius: 10px;
          border: 1px solid #e5e7eb;
          background: #f8fafc;
          color: #6b7280;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: all 0.2s ease;
        }
        .icon-btn:hover {
          border-color: #1E4A7B;
          background: #e8f2ff;
          color: #1E4A7B;
        }
        .dropdown-menu {
          border: 1px solid #e5e7eb;
          border-radius: 12px;
          box-shadow: 0 10px 30px rgba(0,0,0,0.08);
          min-width: 140px;
        }
        .dropdown-item {
          font-size: 13px;
          color: #475569;
          display: flex;
          align-items: center;
          gap: 8px;
          padding: 8px 12px;
          transition: all 0.15s ease;
        }
        .dropdown-item:hover {
          background: #f8fbff;
          color: #1E4A7B;
        }
        .text-danger-600 {
          color: #dc2626;
        }
        .btn-primary {
          background: #1E4A7B;
          border-color: #1E4A7B;
        }
        .btn-primary:hover,
        .btn-primary:focus {
          background: #16385c;
          border-color: #16385c;
        }
