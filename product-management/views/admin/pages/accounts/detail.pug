extend ../../layouts/default.pug

block main  
   
    if(role.permissions.includes("accounts_view"))
        .container.py-5
            .row.justify-content-center
                .col-lg-8.col-md-10
                    .card.border-0.shadow-lg.rounded-4.overflow-hidden
                        .card-header.bg-gradient-primary.text-white.py-4
                            .d-flex.align-items-center
                                
                                div
                                    h1(class="h3 mb-0 fw-bold") Chi tiết tài khoản
                                    
                        
                        .card-body.p-4.bg-light
                            .row.g-4
                                .col-12
                                    .card.border-0.shadow-sm
                                        .card-body
                                            if(data.avatar)
                                                .text-center.mb-4
                                                    img(
                                                        src=data.avatar 
                                                        class="rounded-circle shadow-sm"
                                                        style="width: 150px; height: 150px; object-fit: cover;"
                                                    )
                                
                                .col-md-6
                                    .card.border-0.shadow-sm
                                        .card-body
                                            .d-flex.align-items-center.mb-3
                                                
                                                h5(class="mb-0") Họ tên
                                            if(data.fullName)
                                                p(class="mb-0 text-muted") #{data.fullName}
                                
                                .col-md-6
                                    .card.border-0.shadow-sm
                                        .card-body
                                            .d-flex.align-items-center.mb-3
                                               
                                                h5(class="mb-0") Email
                                            if(data.email)
                                                p(class="mb-0 text-muted") #{data.email}
                                
                                .col-md-6
                                    .card.border-0.shadow-sm
                                        .card-body
                                            .d-flex.align-items-center.mb-3
                                                
                                                h5(class="mb-0") Phân quyền
                                            if(data.role_id)
                                                p(class="mb-0 text-muted") #{role.title}
                                
                                .col-md-6
                                    .card.border-0.shadow-sm
                                        .card-body
                                            .d-flex.align-items-center.mb-3
                                               
                                                h5(class="mb-0") Trạng thái
                                            if(data.status)
                                                if (data.status === "active")
                                                    span(class="badge bg-success p-2") 
                                                        i(class="fas fa-check-circle me-1")
                                                        | Hoạt động
                                                else 
                                                    span(class="badge bg-danger p-2")
                                                        i(class="fas fa-times-circle me-1")
                                                        | Dừng hoạt động

                            .d-grid.gap-3.d-md-flex.justify-content-md-end.mt-5
                                a(
                                    href=`${prefixAdmin}/accounts`
                                    class="btn btn-outline-secondary btn-lg me-md-2"
                                )
                                    
                                    | Quay lại
                                if(role.permissions.includes("accounts_edit"))
                                    a(
                                        href=`${prefixAdmin}/accounts/edit/${data.id}`
                                        class="btn btn-primary btn-lg px-4"
                                    )
                                        
                                        | Chỉnh sửa
                                    
        style.
            .bg-gradient-primary {
                background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%);
            }
            .icon-circle {
                width: 60px;
                height: 60px;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .card {
                border-radius: 16px;
                box-shadow: 0 6px 20px rgba(15,47,79,0.06);
                border: none;
                transition: all 0.25s ease;
            }
            .card:hover {
                box-shadow: 0 12px 30px rgba(15,47,79,0.12);
                transform: translateY(-2px);
            }
            .card-body {
                padding: 24px;
            }
            .badge {
                padding: 6px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 600;
            }
            .badge-success {
                background: #e8f2ff;
                color: #1E4A7B;
            }
            .badge-danger {
                background: #fdecef;
                color: #E5989B;
            }
            .btn-primary {
                background: #1E4A7B;
                border-color: #1E4A7B;
            }
            .btn-primary:hover,
            .btn-primary:focus {
                background: #16385c;
                border-color: #16385c;
            }
            .btn-outline-secondary {
                color: #6b7280;
                border-color: #d1d5db;
            }
            .btn-outline-secondary:hover,
            .btn-outline-secondary:focus {
                color: #fff;
                background: #6b7280;
                border-color: #6b7280;
            }


