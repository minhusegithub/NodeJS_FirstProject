mixin table-tree(items, level = 1)
  each item in items
    - const prefix = Array(level + 1).join("#")
    tr.table-row.align-middle
      td.text-center
        input(
          type="checkbox"
          name="id"
          value=item.id
        )
      td.text-center.text-muted #{item.index}
      td.text-left
        span.d-inline-block(style="min-width: 12px;") #{prefix}
        | #{" "+ item.title}

      td.text-center
        if item.status == "active"
          span.status-badge.status-active Hoạt động
        else
          span.status-badge.status-inactive Dừng hoạt động

      td.text-center
        .dropdown
          button.btn.btn-light.btn-sm.icon-btn.dropdown-toggle(
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            title="Tùy chọn"
          )
            i.bi.bi-three-dots-vertical
          .dropdown-menu.dropdown-menu-right
            a.dropdown-item(href=`${prefixAdmin}/products-category/detail/${item.id}`)
              
              | Xem chi tiết
            if role.permissions.includes("products-category_edit")
              a.dropdown-item(href=`${prefixAdmin}/products-category/edit/${item.id}`)
                
                | Chỉnh sửa
            if role.permissions.includes("products-category_delete")
              button.dropdown-item.text-danger(
                type="button"
                button-delete 
                data-id=item.id
              )
                
                | Xóa

    if item.children && item.children.length > 0
      +table-tree(item.children, level + 1)
