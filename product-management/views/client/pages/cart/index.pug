extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main 
    
    +alert-success(5000)
    +alert-error(5000)

   
    .container.my-3 
        .row 
            .col-12 
                +box-head("Giỏ hàng")


        .row 
            .col-12 
                .card.cart-card.border-0.shadow-sm
                    .card-body
                        .table-responsive
                            table.table.cart-table.align-middle.mb-0
                                thead 
                                    tr 
                                        th #
                                        th Ảnh
                                        th Tên sản phẩm
                                        th Giá
                                        th Số lượng
                                        th Tổng tiền
                                        th Hành động
                                tbody 
                                    if(cartDetail.products.length > 0)
                                        each item,index in cartDetail.products
                                            tr
                                                td #{index+1}
                                                td 
                                                    img.rounded.border(src=item.productInfo.thumbnail , alt="" width="80px")
                                                td
                                                    a.fw-semibold.text-dark(href=`/products/detail/${item.productInfo.slug}`) #{item.productInfo.title}
                                                td #{item.productInfo.priceNew}$
                                                td
                                                    input(
                                                        type="number"
                                                        name="quantity"
                                                        value=item.quantity 
                                                        min="1"
                                                        product-id= item.product_id
                                                        class="form-control quantity-input"
                                                    ) 
                                                td #{item.totalPrice}$
                                                td 
                                                    a(
                                                        href=`/cart/delete/${item.product_id}`
                                                        class="btn btn-light btn-sm btn-delete"
                                                    ) Xóa
                                    else 
                                         tr
                                            td(colspan="7" class="text-center text-muted py-4") Không có sản phẩm nào trong giỏ hàng

                        .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2.mt-3
                            h3.mb-0.fs-5.text-primary Tổng đơn hàng: 
                                span(class="text-success fw-semibold") #{cartDetail.totalPrice}$
                            if(miniCart.totalQuantity > 0 && miniCart.totalQuantity <= 20)
                                a(href="/checkout" class="btn btn-primary px-4") THANH TOÁN 
                            if(miniCart.totalQuantity > 20)
                                p(class="text-danger mb-0 fw-semibold") Số lượng sản phẩm trong giỏ hàng không được vượt quá 20 sản phẩm
                
    script(src="/js/cart.js")

    style.
        .cart-card {
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 47, 79, 0.08);
        }
        .cart-card .card-body {
            padding: 20px;
        }
        .cart-table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
            padding: 14px 12px;
        }
        .cart-table td {
            vertical-align: middle;
            padding: 14px 12px;
            border-color: #e5e7eb;
            text-align: center;
        }
        .cart-table tbody tr:hover {
            background: #f8fbff;
            
        }
        .cart-table img {#
            object-fit: cover;
            height: 64px;
            width: 64px;
        }
        .quantity-input {
            max-width: 150px;
            border-radius: 10px;
            border: 1px solid #d1d5db;
            margin: 0 auto;
            //- text-align: center;
        }
        .quantity-input:focus {
            border-color: #1E4A7B;
            box-shadow: 0 0 0 0.2rem rgba(30, 74, 123, 0.15);
        }
        .btn-delete {
            color: #dc2626;
            border: 1px solid #fecaca;
            background: #fff5f5;
            border-radius: 10px;
            transition: all 0.2s ease;
        }
        .btn-delete:hover {
            background: #fee2e2;
            border-color: #dc2626;
            color: #b91c1c;
        }
        .btn-primary {
            background: #1E4A7B;
            border-color: #1E4A7B;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        .btn-primary:hover {
            background: #16385c;
            border-color: #16385c;
        }
        .text-primary {
            color: #1E4A7B !important;
        }
        @media (max-width: 768px) {
            .cart-card .card-body {
                padding: 16px;
            }
            .cart-table thead {
                font-size: 13px;
            }
            .quantity-input {
                max-width: 70px;
            }
        }







