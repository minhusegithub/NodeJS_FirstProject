extends ../../layouts/auth.pug
include ../../mixins/alert.pug

block main 
    +alert-error(5000)
    
    .forgot-password-page
        .container
            .row.justify-content-center.align-items-center.min-vh-100
                .col-11.col-sm-6.col-md-5.col-lg-4
                    .card.border-0.shadow.rounded-4
                        .card-body.p-4
                            .text-center.mb-4
                                h2.fw-bold.FORGOT1-css Quên mật khẩu
                                p.text-muted Nhập email để nhận mã xác nhận
                            
                            form(
                                action=`/user/password/forgot`
                                method="POST"
                                autocomplete="off"
                            )
                                .form-group.mb-3
                                    input(
                                        type="email"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="email"
                                        name="email"
                                        placeholder="Email"
                                        required
                                    )

                                button(
                                    type="submit"
                                    class="btn btn-primary btn-lg w-100 rounded-3 mb-3"
                                ) Gửi email xác nhận

                                .text-center
                                    a.btn.btn-outline-secondary.btn-lg.w-100.rounded-3(href="/user/login") Quay lại đăng nhập

    style.
        .FORGOT1-css {
            color: #1E4A7B;
        }

        .forgot-password-page {
            background: linear-gradient(135deg, #163a63 0%, #ffffff 100%);
            min-height: 100vh;
        }
        .forgot-password-page .card {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
        }
        .forgot-password-page .form-control {
            padding: 0.8rem 1rem;
            font-size: 15px;
        }
        .forgot-password-page .form-control:focus {
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(30, 74, 123, 0.25);
            border: none;
        }
        .forgot-password-page .form-control::placeholder {
            color: #90949c;
        }
        .forgot-password-page .btn-primary {
            background: #1E4A7B;
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .forgot-password-page .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(30, 74, 123, 0.4);
            background: #163a63;
        }
        .forgot-password-page .btn-outline-secondary {
            border: 2px solid #6c757d;
            color: #6c757d;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .forgot-password-page .btn-outline-secondary:hover {
            background: #6c757d;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(108, 117, 125, 0.3);
        }
        .forgot-password-page h2 {
            color: #1E4A7B;
        }
        .forgot-password-page .text-muted {
            color: #6c757d !important;
        }

               







