extends ../../layouts/auth.pug
include ../../mixins/alert.pug

block main 
    +alert-error(5000)
    
    .register-page
        .container
            .row.justify-content-center.align-items-center.min-vh-100
                .col-11.col-sm-6.col-md-5.col-lg-4
                    .card.border-0.shadow.rounded-4
                        .card-body.p-4
                            .text-center.mb-4
                                h2.fw-bold.register-css Đăng Ký
                            form(
                                action=`/user/register`
                                method="POST"
                                autocomplete="off"
                            )
                                .form-group.mb-3
                                    input(
                                        type="text"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="fullName"
                                        name="fullName"
                                        placeholder="Họ và tên"
                                        required
                                    )

                                .form-group.mb-3
                                    input(
                                        type="email"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="email"
                                        name="email"
                                        placeholder="Email"
                                        required
                                    )

                                .form-group.mb-3
                                    input(
                                        type="password"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="password"
                                        name="password"
                                        placeholder="Mật khẩu"
                                        required
                                    )

                                button(
                                    type="submit"
                                    class="btn btn-success btn-lg w-100 rounded-3 mb-3"
                                ) Tạo tài khoản mới

                                .text-center
                                    a.btn.btn-primary.btn-lg.w-100.rounded-3(href="/user/login") Đăng nhập

    style.
        .register-css {
            color: #1E4A7B;
        }

        .register-page {
            background: linear-gradient(135deg, #163a63 0%, #ffffff 100%);
            min-height: 100vh;
        }
        .register-page .card {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
        }
        .register-page .form-control {
            padding: 0.8rem 1rem;
            font-size: 15px;
        }
        .register-page .form-control:focus {
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(30, 74, 123, 0.25);
            border: none;
        }
        .register-page .form-control::placeholder {
            color: #90949c;
        }
        .register-page .btn-success {
            background: #E5989B;
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .register-page .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(229, 152, 155, 0.4);
            background: #d17f82;
        }
        .register-page .btn-primary {
            background: #1E4A7B;
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .register-page .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(30, 74, 123, 0.4);
            background: #163a63;
        }







