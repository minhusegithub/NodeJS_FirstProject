extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main  
    +alert-success(5000)
    +alert-error(5000)
    
    .user-edit-page
        .container.py-5
            .row.justify-content-center
                .col-lg-10.col-xl-8
                    .info-header.mb-4
                        h1.page-title
                            i.bi.bi-pencil-square.me-2
                            | Chỉnh sửa thông tin
                        
                    
                    .card.edit-card.border-0.shadow-sm
                        .card-body.p-4.p-md-5
                            form(
                                action=`/user/edit?_method=PATCH`
                                method="POST"
                                enctype="multipart/form-data"
                            )
                                .row.mb-4
                                    .col-12.text-center
                                        .avatar-upload
                                            .avatar-preview(upload-image)
                                                if user.avatar
                                                    img.avatar-edit-image(src=user.avatar, upload-image-preview)
                                                else
                                                    img.avatar-edit-image(src="/images/default-avatar.png", upload-image-preview)
                                            .avatar-upload-btn
                                                label.btn.btn-upload(for="avatar")
                                                    i.bi.bi-camera-fill.me-2
                                                    | Chọn ảnh
                                                input#avatar.d-none(
                                                    type="file"
                                                    name="avatar"
                                                    accept="image/*"
                                                    upload-image-input
                                                )
                                
                                .form-section
                                    .form-group.mb-4
                                        label.form-label(for="fullName")
                                            i.bi.bi-person-fill.me-2
                                            | Họ và tên
                                        input.form-control.form-control-lg(
                                            type="text"
                                            id="fullName"
                                            name="fullName"
                                            value=user.fullName
                                            required
                                            placeholder="Nhập họ và tên"
                                        )
                                    
                                    .form-group.mb-4
                                        label.form-label(for="email")
                                            i.bi.bi-envelope-fill.me-2
                                            | Email
                                        input.form-control.form-control-lg(
                                            type="email"
                                            id="email"
                                            name="email"
                                            value=user.email
                                            required
                                            placeholder="Nhập email"
                                        )
                                    
                                    .form-group.mb-4
                                        label.form-label(for="phone")
                                            i.bi.bi-telephone-fill.me-2
                                            | Số điện thoại
                                        input.form-control.form-control-lg(
                                            type="text"
                                            id="phone"
                                            name="phone"
                                            value=user.phone
                                            placeholder="Nhập số điện thoại"
                                        )
                                    
                                    .form-group.mb-4
                                        label.form-label(for="address")
                                            i.bi.bi-geo-alt-fill.me-2
                                            | Địa chỉ
                                        input.form-control.form-control-lg(
                                            type="text"
                                            id="address"
                                            name="address"
                                            value=user.address
                                            placeholder="Nhập địa chỉ"
                                        )
                                    
                                    .form-group.mb-4
                                        label.form-label(for="password")
                                            i.bi.bi-lock-fill.me-2
                                            | Mật khẩu mới (để trống nếu không đổi)
                                        input.form-control.form-control-lg(
                                            type="password"
                                            id="password"
                                            name="password"
                                            placeholder="Nhập mật khẩu mới"
                                        )
                                
                                .form-actions.mt-5
                                    .row.g-3
                                        .col-md-6
                                            a.btn.btn-cancel.btn-lg.w-100(href="/user/info")
                                                i.bi.bi-arrow-left.me-2
                                                | Quay lại
                                        .col-md-6
                                            button.btn.btn-submit.btn-lg.w-100(type="submit")
                                                i.bi.bi-check-circle-fill.me-2
                                                | Cập nhật

    style.
        .user-edit-page {
            background-color: #ffffff;
            padding-bottom: 60px;
        }
        
        .info-header {
            text-align: center;
        }
        
        .page-title {
            color: #1E4A7B;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .page-subtitle {
            color: #666;
            font-size: 16px;
            margin-bottom: 0;
        }
        
        .edit-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
            transition: all 0.3s ease;
        }
        
        .edit-card:hover {
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12) !important;
        }
        
        .avatar-upload {
            position: relative;
            display: inline-block;
        }
        
        .avatar-edit-image {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #e8f2ff;
            box-shadow: 0 4px 12px rgba(30, 74, 123, 0.15);
            margin-bottom: 16px;
        }
        
        .btn-upload {
            background: #E5989B;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .btn-upload:hover {
            background: #d17f82;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(229, 152, 155, 0.3);
            color: #fff;
        }
        
        .form-section {
            margin-top: 32px;
        }
        
        .form-label {
            color: #1E4A7B;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .form-label i {
            color: #E5989B;
        }
        
        .form-control-lg {
            padding: 12px 16px;
            border-radius: 10px;
            border: 2px solid #e0e0e0;
            font-size: 15px;
            transition: all 0.2s ease;
        }
        
        .form-control-lg:focus {
            border-color: #1E4A7B;
            box-shadow: 0 0 0 3px rgba(30, 74, 123, 0.1);
            background: #f8f9fa;
        }
        
        .form-control-lg::placeholder {
            color: #aaa;
        }
        
        .form-actions {
            border-top: 1px solid #e0e0e0;
            padding-top: 24px;
        }
        
        .btn-cancel {
            background: #6c757d;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
            padding: 12px 24px;
        }
        
        .btn-cancel:hover {
            background: #5a6268;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.3);
        }
        
        .btn-submit {
            background: #1E4A7B;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
            padding: 12px 24px;
        }
        
        .btn-submit:hover {
            background: #E5989B;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(229, 152, 155, 0.4);
        }
        
        @media (max-width: 768px) {
            .page-title {
                font-size: 24px;
            }
            
            .avatar-edit-image {
                width: 120px;
                height: 120px;
            }
            
            .form-control-lg {
                padding: 10px 14px;
            }
        }
    
    script(src="/js/script.js")