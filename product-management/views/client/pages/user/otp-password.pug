extends ../../layouts/auth.pug
include ../../mixins/alert.pug

block main 
    +alert-error(5000)
    
    .otp-password-page
        .container
            .row.justify-content-center.align-items-center.min-vh-100
                .col-11.col-sm-6.col-md-5.col-lg-4
                    .card.border-0.shadow.rounded-4
                        .card-body.p-4
                            .text-center.mb-4
                                h2.fw-bold.OTP1-css Xác thực OTP
                                p.text-muted Nhập mã OTP đã gửi đến email của bạn
                            
                            form(
                                action=`/user/password/otp`
                                method="POST"
                                autocomplete="off"
                            )
                                .form-group.mb-3
                                    input(
                                        type="email"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="email"
                                        name="email"
                                        value=email
                                        readonly
                                    )

                                .form-group.mb-3
                                    input(
                                        type="text"
                                        class="form-control form-control-lg rounded-3 border-0 bg-light"
                                        id="otp"
                                        name="otp"
                                        placeholder="Nhập mã OTP"
                                        required
                                    )

                                button(
                                    type="submit"
                                    class="btn btn-primary btn-lg w-100 rounded-3"
                                ) Xác nhận

    style.
        OTP1-css {
            color: #1E4A7B;
        }

        .otp-password-page {
            background: linear-gradient(135deg, #163a63 0%, #ffffff 100%);
            min-height: 100vh;
        }
        .otp-password-page .card {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
        }
        .otp-password-page .form-control {
            padding: 0.8rem 1rem;
            font-size: 15px;
        }
        .otp-password-page .form-control:focus {
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(30, 74, 123, 0.25);
            border: none;
        }
        .otp-password-page .form-control::placeholder {
            color: #90949c;
        }
        .otp-password-page .form-control[readonly] {
            background-color: #e9ecef;
            cursor: not-allowed;
        }
        .otp-password-page .btn-primary {
            background: #1E4A7B;
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .otp-password-page .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(30, 74, 123, 0.4);
            background: #163a63;
        }
        .otp-password-page h2 {
            color: #1E4A7B;
        }
        .otp-password-page .text-muted {
            color: #6c757d !important;
        }

               







