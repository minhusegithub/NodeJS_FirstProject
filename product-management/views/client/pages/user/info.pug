extends ../../layouts/default.pug

block main  
    .user-info-page
        .container.py-5
            .row.justify-content-center
                .col-lg-10.col-xl-8
                    .info-header.mb-4
                        h1.page-title
                            i.bi.bi-person-circle.me-2
                            | Thông tin tài khoản
                        
                    
                    .card.info-card.border-0.shadow-sm
                        .card-body.p-4.p-md-5
                            .row
                                .col-md-4.text-center.mb-4.mb-md-0
                                    .avatar-wrapper
                                        img.avatar-image(src=user.avatar || "/images/default-avatar.png", alt="Avatar")
                                        .avatar-badge
                                            i.bi.bi-check-circle-fill
                                
                                .col-md-8
                                    .info-list
                                        .info-item
                                            .info-label
                                                i.bi.bi-person-fill.me-2
                                                | Họ và tên
                                            .info-value #{user.fullName}
                                        
                                        .info-item
                                            .info-label
                                                i.bi.bi-envelope-fill.me-2
                                                | Email
                                            .info-value #{user.email}
                                        
                                        .info-item
                                            .info-label
                                                i.bi.bi-telephone-fill.me-2
                                                | Số điện thoại
                                            .info-value #{user.phone || "Chưa cập nhật"}
                                        
                                        .info-item
                                            .info-label
                                                i.bi.bi-geo-alt-fill.me-2
                                                | Địa chỉ
                                            .info-value #{user.address || "Chưa cập nhật"}
                            
                            .row.mt-4
                                .col-12.text-center.text-md-end
                                    a.btn.btn-edit.btn-lg(href="/user/edit")
                                        i.bi.bi-pencil-square.me-2
                                        | Chỉnh sửa thông tin

    style.
        .user-info-page {
            background-color: #ffffff;
            padding-bottom: 60px;
        }
        
        .info-header {
            text-align: center;
        }
        
        .page-title {
            color: #1E4A7B;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .page-subtitle {
            color: #666;
            font-size: 16px;
            margin-bottom: 0;
        }
        
        .info-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
            transition: all 0.3s ease;
        }
        
        .info-card:hover {
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12) !important;
        }
        
        .avatar-wrapper {
            position: relative;
            display: inline-block;
        }
        
        .avatar-image {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #e8f2ff;
            box-shadow: 0 4px 12px rgba(30, 74, 123, 0.15);
        }
        
        .avatar-badge {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background: #fff;
            border-radius: 50%;
            padding: 4px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .avatar-badge i {
            color: #28a745;
            font-size: 24px;
            display: block;
        }
        
        .info-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        
        .info-item {
            padding: 16px;
            background: #f8f9fa;
            border-radius: 12px;
            transition: all 0.2s ease;
        }
        
        .info-item:hover {
            background: #e8f2ff;
            transform: translateX(5px);
        }
        
        .info-label {
            color: #1E4A7B;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .info-label i {
            color: #E5989B;
        }
        
        .info-value {
            color: #333;
            font-size: 16px;
            font-weight: 500;
            padding-left: 26px;
        }
        
        .btn-edit {
            background: #1E4A7B;
            color: #fff;
            border: none;
            padding: 12px 32px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-family: 'Inter', 'Poppins', 'Roboto', sans-serif;
        }
        
        .btn-edit:hover {
            background: #E5989B;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(229, 152, 155, 0.4);
        }
        
        @media (max-width: 768px) {
            .page-title {
                font-size: 24px;
            }
            
            .avatar-image {
                width: 140px;
                height: 140px;
            }
            
            .info-item {
                padding: 12px;
            }
        }
                                





