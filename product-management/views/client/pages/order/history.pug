extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug
include ../../mixins/moment.pug

block main 
    +alert-success(5000)
    +alert-error(5000)

    .container-fluid.my-4(style="max-width: 85%;") 
        .row.mb-4
            .col-12 
                .d-flex.justify-content-between.align-items-center
                    div
                        +box-head("Lịch sử đặt hàng")
                    button(
                        class="btn btn-outline-secondary rounded-3"
                        button-go-back
                    ) 
                        
                        | Trở lại

        .row 
            .col-12 
                .card.orders-card.border-0.shadow-sm
                    .card-header.bg-gradient-primary.text-white.py-3
                        h5.mb-0.fw-bold
                            
                            | Tất cả đơn hàng
                    .card-body.p-0
                        .table-responsive(style="max-height: 700px; overflow-y: auto;")
                            table.table.order-table.align-middle.mb-0
                                thead.sticky-top
                                    tr 
                                        th STT
                                        th Ảnh
                                        th Tên sản phẩm
                                        th Giá
                                        th Số lượng
                                        th Phương thức thanh toán
                                        th Giao hàng nhanh
                                        th Tổng tiền
                                        th Ngày đặt hàng
                                tbody 
                                    each item, index in orders
                                        - const rowSpan = item.products.length
                                        each product, productIndex in item.products
                                            tr 
                                                if productIndex === 0
                                                    td(rowspan=rowSpan) #{index + 1}
                                                td
                                                    img.rounded.border(
                                                        src=product.thumbnail
                                                        alt=product.title
                                                        width="80px"
                                                        height="80px"
                                                    )
                                                td.fw-semibold #{product.title}
                                                td #{product.priceNew}$
                                                td #{product.quantity}
                                                if productIndex === 0
                                                    td(rowspan=rowSpan)
                                                        span.badge-payment-method #{item.paymentMethod}
                                                    td(rowspan=rowSpan)
                                                        span(class=item.isPlaceRushOrder ? "badge-success-rush" : "badge-secondary-rush")
                                                            | #{item.isPlaceRushOrder ? "Có" : "Không"}
                                                    td(rowspan=rowSpan).fw-bold.text-success #{item.totalPrice}$
                                                    td(rowspan=rowSpan) 
                                                        +formatDateTime(item.createdAt)

    style.
        .bg-gradient-primary {
            background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%);
        }
        .orders-card {
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 47, 79, 0.08);
        }
        .orders-card .card-header {
            border-radius: 14px 14px 0 0;
            border: none;
        }
        .order-table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
            padding: 14px 12px;
            top: 0;
            z-index: 10;
        }
        .order-table td {
            padding: 14px 12px;
            border-color: #e5e7eb;
            text-align: center;
            vertical-align: middle;
        }
        .order-table tbody tr:hover {
            background: #f8fbff;
        }
        .order-table img {
            object-fit: cover;
            height: 64px;
            width: 64px;
        }
        .badge-payment-method {
            display: inline-block;
            background: #e8f2ff;
            color: #1E4A7B;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-success-rush {
            display: inline-block;
            background: #dcfce7;
            color: #15803d;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-secondary-rush {
            display: inline-block;
            background: #f3f4f6;
            color: #6b7280;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }
        .btn-outline-secondary {
            color: #6b7280;
            border-color: #d1d5db;
            transition: all 0.2s ease;
        }
        .btn-outline-secondary:hover {
            background: #6b7280;
            border-color: #6b7280;
            color: #fff;
        }
        .text-success {
            color: #16a34a !important;
        }
        @media (max-width: 768px) {
            .order-table thead th {
                font-size: 12px;
                padding: 10px 6px;
            }
            .order-table td {
                padding: 10px 6px;
                font-size: 13px;
            }
        }





