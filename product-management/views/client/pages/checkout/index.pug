extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main  
    +alert-success(5000)
    +alert-error(5000)
    
    .container.my-3     
        .row  
            .col-12 
                +box-head("Đặt hàng")

        .row 
            .col-12 
                .card.checkout-card.border-0.shadow-sm
                    .card-body
                        .table-responsive
                            table.table.checkout-table.align-middle.mb-0
                                thead 
                                    tr 
                                        th #
                                        th Ảnh
                                        th Tên
                                        th Giá
                                        th Số lượng
                                        th Tổng tiền
                                        
                                tbody 
                                    if(cartDetail.products.length > 0)
                                        each item,index in cartDetail.products
                                            tr
                                                td #{index+1}
                                                td 
                                                    img.rounded.border(src=item.productInfo.thumbnail , alt="" width="80px")
                                                
                                                td.fw-semibold #{item.productInfo.title}
                                                td #{item.productInfo.priceNew}$
                                                td #{item.quantity}
                                                td #{item.totalPrice}$
                                    else
                                        tr 
                                            td(
                                                colspan="6"
                                                class="text-center text-muted py-4"
                                            ) Giỏ hàng trống

                        if(cartDetail.products.length > 0)                
                            .d-flex.justify-content-end.mt-3.flex-column.align-items-end
                                if(order && order.rushOrder)
                                    div.mb-2.fw-semibold Phí giao hàng nhanh (5%):
                                        span.text-success.ms-2 #{ " " + order.rushOrder}$
                                div.fs-5.fw-bold.text-primary Tổng đơn hàng:
                                    span.text-success.ms-2 #{" " + cartDetail.totalPrice}$

        if(cartDetail.products.length > 0)
            .row 
                .col-12 
                    .card.form-card.border-0.shadow-sm.mt-4
                        .card-header.bg-gradient-primary.text-white.py-3
                            h2.h5.mb-0.fw-bold Thông tin đơn hàng
                        .card-body.p-4
                            form(
                                action="/checkout/realPayment"
                                method="POST"
                                id="checkout-form"
                            )
                                .row
                                    .col-md-6
                                        div(class="form-group mb-3")
                                            label(for="fullName" class="form-label fw-semibold") Họ tên 
                                            input(
                                                type="text"
                                                class="form-control checkout-input"
                                                id="fullName"
                                                name="fullName"
                                                value= order ? order.userInfo.fullName : ""
                                                required
                                            ) 
                                    .col-md-6
                                        div(class="form-group mb-3")
                                            label(for="phone" class="form-label fw-semibold") Số điện thoại 
                                            input(
                                                type="text"
                                                class="form-control checkout-input"
                                                id="phone"
                                                name="phone"
                                                value= order ? order.userInfo.phone : ""
                                                required
                                            )
                                
                                .col-12
                                    div(class="form-group mb-3")
                                        label(for="address" class="form-label fw-semibold") Địa chỉ
                                        input(
                                            type="text"
                                            class="form-control checkout-input"
                                            id="address"
                                            name="address"
                                            value= order ? order.userInfo.address : ""
                                            required
                                        )
                                
                                .row
                                    .col-md-6
                                        div(class="form-group mb-3")
                                            label(for="paymentMethod" class="form-label fw-semibold") 
                                               span Phương thức thanh toán
                                            select(
                                                class="form-control checkout-select"
                                                id="paymentMethod"
                                                name="paymentMethod"
                                                required
                                            )
                                                if(order)
                                                    if(order.paymentMethod === "COD")
                                                        option(value="COD" selected="selected") Thanh toán khi nhận hàng (COD)
                                                        option(value="VNPAY") Thanh toán qua VNPay                   
                                                    else if(order.paymentMethod === "VNPAY")
                                                        option(value="VNPAY" selected="selected") Thanh toán qua VNPay                   
                                                        option(value="COD") Thanh toán khi nhận hàng (COD)                   
                                                    else
                                                        option(value="" disabled="disabled" selected="selected" ) -- Chọn phương thức thanh toán --
                                                        option(value="COD") Thanh toán khi nhận hàng (COD)
                                                        option(value="VNPAY") Thanh toán qua VNPay
                                    
                                    .col-md-6
                                        div(class="form-group mb-3")
                                            label(for="isPlaceRushOrder" class="form-label fw-semibold") 
                                               span Giao hàng nhanh? (Phí: 5%)
                                            select(
                                                class="form-control checkout-select"
                                                id="isPlaceRushOrder"
                                                name="isPlaceRushOrder"
                                                required
                                            )
                                                if(order)
                                                    if(order.isPlaceRushOrder === true)                                      
                                                        option(value="yes" selected="selected") Có 
                                                        option(value="no" ) Không
                                                    else if(order.isPlaceRushOrder === false)                             
                                                        option(value="no" selected="selected") Không
                                                        option(value="yes") Có 
                                                    else
                                                        option(value="" disabled="disabled" selected="selected" ) -- Chọn phương thức giao hàng --
                                                        option(value="yes") Có 
                                                        option(value="no") Không
                                
                                .col-12.mt-3
                                    button(
                                        type="submit"
                                        class="btn btn-primary btn-lg w-100"
                                    ) ĐẶT HÀNG

    script.
        document.getElementById('checkout-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const paymentMethod = document.getElementById('paymentMethod').value;
           

            if(paymentMethod === 'VNPAY') {
                // Chuyển hướng đến trang thanh toán VNPay
                window.location.href = '/checkout/create_payment_url';
            } else {
                // Gửi form bình thường cho COD
                this.submit();
            }
        });
        
    script(src="/js/script.js")

    style.
        .bg-gradient-primary {
            background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%);
        }
        .checkout-card {
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 47, 79, 0.08);
            margin-bottom: 24px;
        }
        .checkout-card .card-body {
            padding: 24px;
        }
        .checkout-card .card-header {
            border-radius: 14px 14px 0 0;
            border: none;
        }
        .checkout-table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
            padding: 14px 12px;
        }
        .checkout-table td {
            vertical-align: middle;
            padding: 14px 12px;
            border-color: #e5e7eb;
            text-align: center;
        }
        .checkout-table tbody tr:hover {
            background: #f8fbff;
        }
        .checkout-table img {
            object-fit: cover;
            height: 64px;
            width: 64px;
        }
        .form-card {
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 47, 79, 0.08);
        }
        .form-card .card-header {
            border-radius: 14px 14px 0 0;
        }
        .checkout-input,
        .checkout-select {
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 5px 5px;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        .checkout-input:focus,
        .checkout-select:focus {
            border-color: #1E4A7B;
            box-shadow: 0 0 0 0.2rem rgba(30, 74, 123, 0.15);
            outline: none;
        }
        .checkout-input::placeholder {
            color: #9ca3af;
        }
        .form-label {
            margin-bottom: 8px;
            color: #1f2937;
        }
        .btn-primary {
            background: #1E4A7B;
            border-color: #1E4A7B;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-weight: 600;
        }
        .btn-primary:hover {
            background: #16385c;
            border-color: #16385c;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(30, 74, 123, 0.3);
        }
        .text-primary {
            color: #1E4A7B !important;
        }
        .text-success {
            color: #16a34a !important;
        }
        @media (max-width: 768px) {
            .checkout-card .card-body {
                padding: 16px;
            }
            .form-card .card-body {
                padding: 16px;
            }
            .checkout-table thead {
                font-size: 13px;
            }
        }  