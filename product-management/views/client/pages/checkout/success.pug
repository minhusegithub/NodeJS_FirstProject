extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main  
    .container.my-5     
        .row  
            .col-12 
               
        .row 
            .col-12 
                .success-alert.alert.alert-success.border-0.shadow-sm.p-5.text-center.rounded-4
                    .success-icon.mb-3
                        i(class="fas fa-check-circle")
                    h3.alert-heading.mb-3.fw-bold Đặt hàng thành công!
                    p.mb-0.fs-6 Chúc mừng bạn đã đặt hàng thành công! Chúng tôi sẽ xử lí đơn hàng trong thời gian sớm nhất

        if(order)
            .row.mt-5
                .col-12 
                    .card.info-card.border-0.shadow-sm
                        .card-header.bg-gradient-primary.text-white.py-3
                            h5.mb-0.fw-bold
                                i(class="fas fa-user-circle me-2")
                                | Thông tin cá nhân 
                        .card-body.p-4
                            table.table.info-table.mb-0
                                tbody 
                                    tr 
                                        td.label-cell Họ tên 
                                        td 
                                            b #{order.userInfo.fullName}
                                    tr 
                                        td.label-cell Số điện thoại 
                                        td 
                                            b #{order.userInfo.phone}
                                    tr 
                                        td.label-cell Địa chỉ
                                        td 
                                            b #{order.userInfo.address}
                                    tr 
                                        td.label-cell Giao hàng nhanh
                                        td 
                                            b 
                                                span(class=order.isPlaceRushOrder ? "badge-success-modern" : "badge-secondary-modern")
                                                    | #{order.isPlaceRushOrder ? "Có" : "Không"}
                                    tr 
                                        td.label-cell Phương thức thanh toán
                                        td 
                                            b 
                                                span(class="badge-primary-modern")
                                                    | #{order.paymentMethod}
            
            .row.mt-4
                .col-12 
                    .card.info-card.border-0.shadow-sm
                        .card-header.bg-gradient-primary.text-white.py-3
                            h5.mb-0.fw-bold
                                i(class="fas fa-shopping-cart me-2")
                                | Thông tin đơn hàng
                        .card-body.p-4
                            .table-responsive
                                table.table.product-table.align-middle.mb-0
                                    thead 
                                        tr 
                                            th STT
                                            th Ảnh
                                            th Tên
                                            th Giá
                                            th Số lượng
                                            th Tổng tiền
                                    tbody 
                                        if(order.products.length > 0)
                                            each item,index in order.products 
                                                tr 
                                                    td #{index+1}
                                                    td
                                                        img.rounded.border(
                                                            src=item.productInfo.thumbnail 
                                                            alt=item.productInfo.title
                                                            width="80px"
                                                        )
                                                    td.fw-semibold #{item.productInfo.title}
                                                    td #{item.priceNew}$
                                                    td #{item.quantity}
                                                    td.fw-semibold #{item.totalPrice}$

                        if(order.products.length > 0)
                            .card-footer.bg-white.border-top
                                .d-flex.justify-content-between.align-items-center
                                    h5.mb-0.fw-bold Tổng đơn hàng:
                                    h5.mb-0.text-success.fw-bold #{order.totalPrice}$

            .row.mt-5.mb-3
                .col-12.d-flex.gap-2.justify-content-center
                    button.btn.btn-primary.btn-lg(onclick="window.location.href='/'") 
                        i.fas.fa-home.me-2
                        | Quay về trang chủ

    style.
        .bg-gradient-primary {
            background: linear-gradient(135deg, #1E4A7B 0%, #16385c 100%);
        }
        .success-alert {
            background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
            border: 2px solid #16a34a;
        }
        .success-icon {
            font-size: 56px;
            color: #16a34a;
            animation: bounce 1s ease-in-out;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .alert-heading {
            color: #15803d;
            font-size: 24px;
        }
        .info-card {
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 47, 79, 0.08);
        }
        .info-card .card-header {
            border-radius: 14px 14px 0 0;
            border: none;
        }
        .info-card .card-body {
            padding: 24px;
        }
        .info-table {
            border: none;
        }
        .info-table tbody tr {
            border-bottom: 1px solid #e5e7eb;
        }
        .info-table tbody tr:last-child {
            border-bottom: none;
        }
        .info-table tbody tr:hover {
            background: #f8fbff;
        }
        .info-table td {
            padding: 14px 12px;
            vertical-align: middle;
        }
        .label-cell {
            color: #6b7280;
            font-weight: 600;
            width: 200px;
        }
        .info-table td b {
            color: #1f2937;
        }
        .badge-success-modern {
            display: inline-block;
            background: #dcfce7;
            color: #15803d;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
        }
        .badge-secondary-modern {
            display: inline-block;
            background: #f3f4f6;
            color: #6b7280;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
        }
        .badge-primary-modern {
            display: inline-block;
            background: #e8f2ff;
            color: #1E4A7B;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
        }
        .product-table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
            padding: 14px 12px;
        }
        .product-table td {
            padding: 14px 12px;
            border-color: #e5e7eb;
            text-align: center;
        }
        .product-table tbody tr:hover {
            background: #f8fbff;
        }
        .product-table img {
            object-fit: cover;
            height: 64px;
            width: 64px;
        }
        .card-footer {
            background: #f8fafc !important;
            border-radius: 0 0 14px 14px;
            padding: 16px 24px;
        }
        .btn-primary {
            background: #1E4A7B;
            border-color: #1E4A7B;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-weight: 600;
        }
        .btn-primary:hover {
            background: #16385c;
            border-color: #16385c;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(30, 74, 123, 0.3);
        }
        .text-success {
            color: #16a34a !important;
        }
        @media (max-width: 768px) {
            .info-card .card-body {
                padding: 16px;
            }
            .label-cell {
                width: auto;
            }
            .success-icon {
                font-size: 42px;
            }
        }


        