mixin product-item(item)
    -const priceNew = Math.round(item.price * (1 - item.discountPercentage / 100));
    .col-3.mb-4
        .product-item
            .product-image-wrapper
                .product-image
                    img(src=item.thumbnail, alt=item.title, loading="lazy")
                
                if(item.featured == "1")
                    .product-badge.badge-featured
                        i.bi.bi-star-fill
                        | Nổi bật
                
                if(item.discountPercentage > 0)
                    .product-badge.badge-discount -#{item.discountPercentage}%
                
                .product-overlay
                    a.btn-view(href=`/products/detail/${item.slug}`, title="Xem chi tiết")
                        i.bi.bi-eye
                        span Xem chi tiết
            
            .product-content
                .product-title
                    a(href=`/products/detail/${item.slug}`, title=item.title) #{item.title}
                
                .product-stock-info
                    if(item.stock <= 0)
                        .stock-badge-item.out-of-stock
                            i.bi.bi-x-circle
                            span Hết hàng
                    else if(item.stock <= 10)
                        .stock-badge-item.low-stock
                            i.bi.bi-exclamation-circle
                            span Còn #{item.stock} sản phẩm
                    else
                        .stock-badge-item.in-stock
                            i.bi.bi-check-circle
                            span Còn hàng
                
                .product-price
                    span.price-new #{priceNew.toLocaleString()}₫
                    if(item.price > priceNew)
                        span.price-old #{Math.round(item.price).toLocaleString()}₫
                
                .product-actions
                    if(item.stock > 0)
                        form(
                            action=`/cart/add/${item._id}`
                            method="POST"
                            class="form-add-cart"
                        )
                            input(type="hidden", name="quantity", value="1")
                            button.btn-add-cart(type="submit", title="Thêm vào giỏ")
                                i.bi.bi-bag-check
                                span Mua ngay
                    else
                        button.btn-add-cart(disabled, type="button", title="Hết hàng")
                            i.bi.bi-x-circle
                            span Hết hàng
